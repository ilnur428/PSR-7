{
  "name": "ilnur428/psr7-decorators",
  "description": "PSR-7 stream decorators for encryption and decryption",
  "keywords": ["psr", "psr-7", "http", "http-message", "request", "response", "decorator", "encryption", "decryption"],
  "type": "library",
  "homepage": "https://github.com/ilnur428/PSR-7",
  "license": "MIT",
  "require": {
    "ext-hash": "*",
    "ext-openssl": "*",
    "php": "^8.1",
    "psr/http-message": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Ilnur428\\Psr7Decorators\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ilnur428\\Psr7Decorators\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "nyholm/psr7": "^1.8"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist"
  }
}